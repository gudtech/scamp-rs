# Build and test scamp-rs against the GT dev environment.
# Run on the gtnet network to reach Perl/Go/JS services.
#
# Build:
#   docker build --platform linux/amd64 -f Dockerfile.interop-test -t scamp-rs-test .
#
# Run interactively:
#   docker run --rm -it --network gtnet \
#     -v ~/GT/backplane:/backplane:ro \
#     scamp-rs-test list actions
#
# Test request to Perl service:
#   docker run --rm --network gtnet \
#     -v ~/GT/backplane:/backplane:ro \
#     scamp-rs-test request --action "api.status.health_check~1" --body '{}'

FROM --platform=linux/amd64 rust:1.82-slim-bookworm AS builder

RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY Cargo.toml Cargo.lock* ./
COPY src/ src/
COPY samples/ samples/

RUN cargo build --release --bin scamp 2>&1

FROM --platform=linux/amd64 debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates libssl3 && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/scamp /usr/local/bin/scamp

ENTRYPOINT ["scamp"]
